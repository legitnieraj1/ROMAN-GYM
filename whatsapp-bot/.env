# ── Roman Fitness WhatsApp Bot ──────────────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to git.

PORT=3001

# xAI Grok API key — get yours at https://console.x.ai
# Used for AI auto-replies when someone messages the gym's WhatsApp
GROK_API_KEY=xai-your-key-here

# Grok model to use (grok-3-mini is fast + cheap for auto-replies)
GROK_MODEL=grok-3-mini

# Auto-reply: set to "true" to enable AI responses on incoming msgs
AUTO_REPLY_ENABLED=true

# Roman Fitness context injected into the Grok system prompt
GYM_NAME=Roman Fitness
GYM_PHONE=+918098834154
GYM_ADDRESS=No 17, Bhagat Singh Nagar, Periyanaickenpalayam, Coimbatore 641020
GYM_TIMINGS=Mon-Sat 5:00 AM – 11:00 PM | Sunday 6:00 AM – 2:00 PM
